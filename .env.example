# Copia este archivo a .env y completa con tus valores reales.
# NUNCA subas .env al repositorio (está en .gitignore).

# URL base de la aplicación bajo prueba
APP_URL=https://tu-app.ejemplo.com

# Credenciales del usuario de prueba
APP_USER=usuario@ejemplo.com
APP_PASS=tu_password_de_prueba

# Ejecutar el navegador en modo headless (true/false). Por defecto: true
HEADLESS=true
